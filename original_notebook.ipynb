    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "import numpy as np\n",
        "import random\n",
        "\n",
        "configs = [\n",
        "    #{\"NumAllGene\": 4, \"NumTF\": 2, \"B\": 1},\n",
        "    {\"NumAllGene\": 2000, \"NumTF\":  1500, \"B\": 1},\n",
        "    #{\"NumAllGene\": 1000, \"NumTF\": 800, \"B\": 1},\n",
        "    #{\"NumAllGene\": 200,\"NumTF\": 150, \"B\": 1},\n",
        "    #{\"NumAllGene\": 200, \"NumTF\": 150, \"B\": 1},\n",
        "\n",
        "\n",
        "\n",
        "]\n",
        "\n",
        "DATA_SEEDS = [11, 22, 33, 44, 55, 66, 77, 88, 99, 111]\n",
        "checkpoints = [0, 1000, 2000, 3000, 4000, 5000]\n",
        "INIT_SEED = 0\n",
        "\n",
        "results = []\n",
        "\n",
        "for cfg in configs:\n",
        "    NumAllGene = cfg[\"NumAllGene\"]\n",
        "    NumTF      = cfg[\"NumTF\"]\n",
        "    B          = cfg[\"B\"]\n",
        "\n",
        "    for run_idx, data_seed in enumerate(DATA_SEEDS, start=1):\n",
        "        print(\"\\n\" + \"=\"*70)\n",
        "        print(f\"CONFIG: G={NumAllGene}, TF={NumTF}, B={B} | DATA RUN {run_idx}/{len(DATA_SEEDS)} | data_seed={data_seed}\")\n",
        "        print(\"=\"*70)\n",
        "\n",
        "        # reproducible data generation for this run\n",
        "        random.seed(data_seed)\n",
        "        np.random.seed(data_seed)\n",
        "        torch.manual_seed(data_seed)\n",
        "        if device.type == \"cuda\":\n",
        "            torch.cuda.manual_seed_all(data_seed)\n",
        "\n",
        "        # 1) Generate data\n",
        "        A_true_, Mask, X0, t_span, x_star_true, Y_clean, Y_obs = build_mask_and_generate_data(\n",
        "            NumAllGene=NumAllGene,\n",
        "            NumTF=NumTF,\n",
        "            B=B,\n",
        "            seed=data_seed,\n",
        "            device=device,\n",
        "        )\n",
        "\n",
        "        # SAME K_time for BOTH models\n",
        "        K_time_run = 1  # or: min(10, Y_obs.shape[1])\n",
        "\n",
        "        # ---- Shared initial A ----\n",
        "        G = Y_obs.shape[2]\n",
        "        dtype = Y_obs.dtype\n",
        "        Mask_f = Mask.to(device=device, dtype=dtype)\n",
        "\n",
        "        torch.manual_seed(INIT_SEED)\n",
        "        if device.type == \"cuda\":\n",
        "            torch.cuda.manual_seed_all(INIT_SEED)\n",
        "\n",
        "        A_init = (0.01 * torch.randn(G, G, device=device, dtype=dtype)) * Mask_f\n",
        "\n",
        "\n",
        "\n",
        "        # ---- Autodiff epoch-0 ----\n",
        "        with torch.no_grad():\n",
        "            model0 = LTIExact(NumAllGene, Mask).to(device=device, dtype=dtype)\n",
        "            model0.W.copy_(A_init.to(device=device, dtype=model0.W.dtype))\n",
        "            Y0_ad = model0(X0, t_span)\n",
        "            ad_loss0 = (F.mse_loss(Y0_ad, Y_obs)\n",
        "                        + 1e-4 * (model0.W * model0.mask).pow(2).sum()).item()\n",
        "\n",
        "        # ---- OurMethod epoch-0 ----\n",
        "        with torch.no_grad():\n",
        "            x_star0 = Y_obs[:, -10:, :].mean(dim=(0, 1)).detach().clone().to(device=device, dtype=dtype)\n",
        "            A0 = A_init * Mask_f\n",
        "            E0 = torch.matrix_exp(A0.unsqueeze(0) * t_span.view(t_span.shape[0], 1, 1))\n",
        "            Y0_our = torch.einsum('tij,bj->bti', E0, (X0 - x_star0)) + x_star0\n",
        "            om_loss0 = F.mse_loss(Y0_our, Y_obs).item()\n",
        "\n",
        "        # 2) AUTODIFF training\n",
        "        ad_loss_hist, ad_time, model = run_autodiff_LTI(\n",
        "            NumAllGene=NumAllGene,\n",
        "            Mask=Mask,\n",
        "            X0=X0,\n",
        "            t_span=t_span,\n",
        "            Y_obs=Y_obs,\n",
        "            device=device,\n",
        "            epochs=5000,\n",
        "            lr=3e-3,\n",
        "            reg_lambda=1e-6,\n",
        "            TIME_IT=True,\n",
        "            print_every=None,\n",
        "            verbose=False,\n",
        "            init_W=A_init,\n",
        "            K_time=K_time_run,\n",
        "        )\n",
        "        ad_final_loss = ad_loss_hist[-1]\n",
        "\n",
        "        with torch.no_grad():\n",
        "            Y_pred_ad = model(X0, t_span)\n",
        "\n",
        "        # 3) OUR METHOD training\n",
        "        A_hat, x_star_hat, Y_pred_our, om_loss_hist, om_time = run_ourmethod_learn_A_xstar(\n",
        "            X0=X0,\n",
        "            Y_obs=Y_obs,\n",
        "            t_span=t_span,\n",
        "            Mask=Mask,\n",
        "            expm_frechet_alg64_pade13=expm_frechet_alg64_pade13,\n",
        "            epochs=5000,\n",
        "            lr_A=3e-3,\n",
        "            lr_xs=3e-3,\n",
        "            K_time=K_time_run,\n",
        "            delta=0.07,\n",
        "            eps=1e-12,\n",
        "            print_every=1000,\n",
        "            seed=0,\n",
        "            do_print=False,\n",
        "            init_A=A_init,\n",
        "        )\n",
        "        om_final_loss = om_loss_hist[-1]\n",
        "\n",
        "        # 4) Print checkpoint losses\n",
        "        print(\"\\nCheckpoint losses (after k epochs):\")\n",
        "        for k in checkpoints:\n",
        "            if k == 0:\n",
        "                ad_k = ad_loss0\n",
        "                om_k = om_loss0\n",
        "            else:\n",
        "                ad_k = ad_loss_hist[k-1]\n",
        "                om_k = om_loss_hist[k-1]\n",
        "            print(f\"  epoch {k:4d} | Autodiff: {ad_k:.6e} | OurModel: {om_k:.6e}\")\n",
        "\n",
        "        # 5) Plot\n",
        "        title = f\"G={NumAllGene}, TF={NumTF}, B={B} | data_run={run_idx} (seed={data_seed})\"\n",
        "        plot_compare_first3dims(t_span, Y_obs, Y_clean, Y_pred_ad, Y_pred_our, title_prefix=title)\n",
        "\n",
        "        # 6) Save row\n",
        "        results.append({\n",
        "            \"NumAllGene\": NumAllGene,\n",
        "            \"NumTF\": NumTF,\n",
        "            \"B\": B,\n",
        "            \"DataRun\": run_idx,\n",
        "            \"DataSeed\": data_seed,\n",
        "            \"K_time\": K_time_run,\n",
        "            \"Autodiff_Time\": ad_time,\n",
        "            \"Autodiff_Loss\": ad_final_loss,\n",
        "            \"OurModel_Time\": om_time,\n",
        "            \"OurModel_Loss\": om_final_loss,\n",
        "        })\n",
        "\n",
        "# Final table\n",
        "df = pd.DataFrame(results, columns=[\n",
        "    \"NumAllGene\", \"NumTF\", \"B\", \"DataRun\", \"DataSeed\", \"K_time\",\n",
        "    \"Autodiff_Time\", \"Autodiff_Loss\",\n",
        "    \"OurModel_Time\", \"OurModel_Loss\"\n",
        "])\n",
        "\n",
        "avg_row = {\n",
        "    \"NumAllGene\": \"AVG_ALL\",\n",
        "    \"NumTF\": \"-\",\n",
        "    \"B\": \"-\",\n",
        "    \"DataRun\": \"-\",\n",
        "    \"DataSeed\": \"-\",\n",
        "    \"K_time\": \"-\",\n",
        "    \"Autodiff_Time\": df[\"Autodiff_Time\"].mean(),\n",
        "    \"Autodiff_Loss\": df[\"Autodiff_Loss\"].mean(),\n",
        "    \"OurModel_Time\": df[\"OurModel_Time\"].mean(),\n",
        "    \"OurModel_Loss\": df[\"OurModel_Loss\"].mean(),\n",
        "}\n",
        "\n",
        "df_final = pd.concat([df, pd.DataFrame([avg_row])], ignore_index=True)\n",
        "\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"FINAL SUMMARY TABLE (all runs) + OVERALL AVG\")\n",
        "print(\"=\"*70)\n",
        "df_final"
