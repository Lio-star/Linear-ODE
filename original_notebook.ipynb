        "def plot_compare_first3dims(t_span, Y_obs, Y_true, Y_pred_ad, Y_pred_our, title_prefix=\"\"):\n",
        "\n",
        "\n",
        "    import matplotlib.pyplot as plt\n",
        "    import numpy as np\n",
        "\n",
        "    t = t_span.detach().cpu().numpy()\n",
        "\n",
        "    def to_BTG(Y):\n",
        "        Y = Y.detach().cpu().numpy()\n",
        "        if Y.ndim == 2:   # [T,G] -> [1,T,G]\n",
        "            Y = Y[None, ...]\n",
        "        return Y\n",
        "\n",
        "    Yo = to_BTG(Y_obs)       # [B,T,G]\n",
        "    Yt = to_BTG(Y_true)      # [B,T,G]\n",
        "    Ya = to_BTG(Y_pred_ad)   # [B,T,G]\n",
        "    Ym = to_BTG(Y_pred_our)  # [B,T,G]\n",
        "\n",
        "    B, T, d = Yo.shape\n",
        "    nd = min(3, d)\n",
        "\n",
        "    fig, axes = plt.subplots(1, nd, figsize=(5 * nd, 4), sharex=True)\n",
        "    if nd == 1:\n",
        "        axes = [axes]\n",
        "\n",
        "    # fixed colors by method\n",
        "    c_true = \"tab:blue\"\n",
        "    c_ad   = \"tab:orange\"\n",
        "    c_our  = \"tab:green\"\n",
        "\n",
        "    for j in range(nd):\n",
        "        ax = axes[j]\n",
        "\n",
        "        for b in range(B):\n",
