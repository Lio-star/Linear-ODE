      "source": [
        "# Algorithm 6.4 (expm + Frechet)\n",
        "\n",
        "#  matrix 1-norm\n",
        "def mat_norm1(A: torch.Tensor) -> torch.Tensor:\n",
        "    # max column-sum norm\n",
        "    return torch.max(torch.sum(torch.abs(A), dim=0))\n",
        "\n",
        "#  Pade coefficients b_k for [m/m] approximant\n",
        "def _pade_b(m: int, dtype, device):\n",
        "    # b_k = (2m-k)! * m! / ((2m)! * (m-k)! * k!)\n",
        "    two_m_fact = math.factorial(2*m)\n",
        "    m_fact = math.factorial(m)\n",
        "    b = []\n",
        "    for k in range(m+1):\n",
        "        num = math.factorial(2*m-k) * m_fact\n",
        "        den = two_m_fact * math.factorial(m-k) * math.factorial(k)\n",
        "        b.append(num / den)\n",
        "    return torch.tensor(b, dtype=dtype, device=device)  # b[0..m]\n",
        "\n",
        "# Compute U,V for general m in {3,5,7,9}\n",
        "def pade_uv(A: torch.Tensor, m: int, I: torch.Tensor):\n",
        "    b = _pade_b(m, A.dtype, A.device)\n",
        "\n",
        "    A2 = A @ A\n",
        "    # Apow[p] = A^(2p), p>=1 up to p=m-1\n",
        "    Apow = [None] * (m)\n",
        "    Apow[1] = A2\n",
        "    for p in range(2, m):\n",
        "        Apow[p] = Apow[p-1] @ A2\n",
        "\n",
        "    # V = b0 I + b2 A^2 + b4 A^4 + ...\n",
        "    V = b[0] * I\n",
        "    for k in range(2, m+1, 2):\n",
        "        p = k // 2\n",
        "        V = V + b[k] * Apow[p]\n",
        "\n",
        "    # W = b1 I + b3 A^2 + b5 A^4 + ...\n",
        "    W = b[1] * I\n",
        "    for k in range(3, m+1, 2):\n",
        "        p = (k - 1) // 2\n",
        "        W = W + b[k] * Apow[p]\n",
        "\n",
        "    U = A @ W\n",
        "    return U, V\n",
        "\n",
        "# Compute Lu,Lv for general m in {3,5,7,9}\n",
        "def pade_frechet_LuLv(A: torch.Tensor, E: torch.Tensor, m: int, I: torch.Tensor):\n",
        "    b = _pade_b(m, A.dtype, A.device)\n",
        "\n",
        "    A2 = A @ A\n",
        "\n",
        "    # M2 = L_{A^2}(A,E) = AE + EA\n",
        "    M2 = A @ E + E @ A\n",
        "\n",
        "    # Apow[p] = A^(2p), Mpow[p] = L_{A^(2p)}(A,E), p>=1\n",
        "    Apow = [None] * (m)\n",
        "    Mpow = [None] * (m)\n",
        "    Apow[1] = A2\n",
        "    Mpow[1] = M2\n",
        "\n",
        "    # Recurrence: M_{2(p+1)} = A^{2p} M2 + M_{2p} A^2\n",
        "    for p in range(2, m):\n",
        "        Apow[p] = Apow[p-1] @ A2\n",
        "        Mpow[p] = Apow[p-1] @ M2 + Mpow[p-1] @ A2\n",
        "\n",
        "    # Lv = sum_{even k} b_k * M_k  (k = 2,4,...,m)\n",
        "    Lv = torch.zeros_like(A)\n",
        "    for k in range(2, m+1, 2):\n",
        "        p = k // 2\n",
        "        Lv = Lv + b[k] * Mpow[p]\n",
        "\n",
        "    # W = b1 I + b3 A^2 + b5 A^4 + ...\n",
        "    W = b[1] * I\n",
        "    for k in range(3, m+1, 2):\n",
        "        p = (k - 1) // 2\n",
        "        W = W + b[k] * Apow[p]\n",
        "\n",
        "    # Lw = sum_{odd k>=3} b_k * M_{k-1}\n",
        "    Lw = torch.zeros_like(A)\n",
        "    for k in range(3, m+1, 2):\n",
        "        p = (k - 1) // 2\n",
        "        Lw = Lw + b[k] * Mpow[p]\n",
        "\n",
        "    # U = A W  =>  Lu = A Lw + E W\n",
        "    Lu = A @ Lw + E @ W\n",
        "    return Lu, Lv\n",
        "\n",
        "#  Algorithm 6.4 (Padé-13 + scaling & squaring)\n",
        "def expm_frechet_alg64_pade13(A: torch.Tensor, E: torch.Tensor):\n",
        "    \"\"\"\n",
        "    Inputs: A, E\n",
        "    Outputs: R = expm(A), L = L_exp(A, E)\n",
        "    \"\"\"\n",
        "    assert A.shape == E.shape and A.ndim == 2 and A.shape[0] == A.shape[1]\n",
        "    n = A.shape[0]\n",
        "    dev = A.device\n",
        "\n",
        "    dtype = A.dtype\n",
        "\n",
        "    # Padé-13 coefficients\n",
        "    b = torch.tensor([\n",
        "        64764752532480000.0,\n",
        "        32382376266240000.0,\n",
        "        7771770303897600.0,\n",
        "        1187353796428800.0,\n",
        "        129060195264000.0,\n",
        "        10559470521600.0,\n",
        "        670442572800.0,\n",
        "        33522128640.0,\n",
        "        1323241920.0,\n",
        "        40840800.0,\n",
        "        960960.0,\n",
        "        16380.0,\n",
        "        182.0,\n",
        "        1.0\n",
        "    ], device=dev, dtype=dtype)\n",
        "\n",
        "    theta_13 = torch.tensor(5.371920351148152, device=dev, dtype=dtype)\n",
        "    I = torch.eye(n, device=dev, dtype=dtype)\n",
        "\n",
        "    # norm-1\n",
        "    A_norm1 = mat_norm1(A)\n",
        "\n",
        "    # Small-norm branches (m = 3,5,7,9)\n",
        "    ell3 = 1.495585217958292e-02\n",
        "    ell5 = 2.539398330063230e-01\n",
        "    ell7 = 9.504178996162932e-01\n",
        "    ell9 = 2.097847961257068e+00\n",
        "\n",
        "    m = None\n",
        "    if A_norm1 <= ell3:\n",
        "        m = 3\n",
        "    elif A_norm1 <= ell5:\n",
        "        m = 5\n",
        "    elif A_norm1 <= ell7:\n",
        "        m = 7\n",
        "    elif A_norm1 <= ell9:\n",
        "        m = 9\n",
        "\n",
        "    if m is not None:\n",
        "        U, V = pade_uv(A, m, I)\n",
        "        Lu, Lv = pade_frechet_LuLv(A, E, m, I)\n",
        "\n",
        "        K = V - U\n",
        "        LU, piv = torch.linalg.lu_factor(K)\n",
        "        R = torch.linalg.lu_solve(LU, piv, V + U)\n",
        "        rhs_L = (Lu + Lv) + (Lu - Lv) @ R\n",
        "        L = torch.linalg.lu_solve(LU, piv, rhs_L)\n",
        "        return R, L\n",
        "\n",
        "    # Scaling\n",
        "    if A_norm1 <= theta_13:\n",
        "        s = 0\n",
        "        A_s = A\n",
        "        E_s = E\n",
        "    else:\n",
        "        s = int(torch.ceil(torch.log2(A_norm1 / theta_13)).item())\n",
        "        scale = 2.0 ** (-s)\n",
        "        A_s = A * scale\n",
        "        E_s = E * scale\n",
        "\n",
        "    # Powers and Frechet powers\n",
        "    A2 = A_s @ A_s\n",
        "    A4 = A2 @ A2\n",
        "    A6 = A2 @ A4\n",
        "\n",
        "    M2 = A_s @ E_s + E_s @ A_s\n",
        "    M4 = A2 @ M2 + M2 @ A2\n",
        "    M6 = A4 @ M2 + M4 @ A2\n",
        "\n",
        "    # Build U,V (Padé-13)\n",
        "    W1 = b[13]*A6 + b[11]*A4 + b[9]*A2\n",
        "    W2 = b[7]*A6  + b[5]*A4  + b[3]*A2 + b[1]*I\n",
        "    Z1 = b[12]*A6 + b[10]*A4 + b[8]*A2\n",
        "    Z2 = b[6]*A6  + b[4]*A4  + b[2]*A2 + b[0]*I\n",
        "\n",
        "    W  = A6 @ W1 + W2\n",
        "    U  = A_s @ W\n",
        "    V  = A6 @ Z1 + Z2\n",
        "\n",
        "    # Build Lu, Lv\n",
        "    Lw1 = b[13]*M6 + b[11]*M4 + b[9]*M2\n",
        "    Lw2 = b[7]*M6  + b[5]*M4  + b[3]*M2\n",
        "    Lz1 = b[12]*M6 + b[10]*M4 + b[8]*M2\n",
        "    Lz2 = b[6]*M6  + b[4]*M4  + b[2]*M2\n",
        "\n",
        "    Lw = A6 @ Lw1 + M6 @ W1 + Lw2\n",
        "    Lu = A_s @ Lw + E_s @ W\n",
        "    Lv = A6 @ Lz1 + M6 @ Z1 + Lz2\n",
        "\n",
        "    # Solves\n",
        "    K = V - U\n",
        "    LU, piv = torch.linalg.lu_factor(K)\n",
        "    R = torch.linalg.lu_solve(LU, piv, V + U)\n",
        "\n",
        "    rhs_L = (Lu + Lv) + (Lu - Lv) @ R\n",
        "    L = torch.linalg.lu_solve(LU, piv, rhs_L)\n",
        "    # Squaring loop\n",
        "    for _ in range(s):\n",
        "        L = R @ L + L @ R\n",
        "        R = R @ R\n",
        "\n",
        "    return R, L\n",
        "\n",
        "\n",
        "_PADE13_CONSTS_CACHE = {}\n",
        "\n",
        "def _get_pade13_consts(n: int, device: torch.device, dtype: torch.dtype):\n",
        "    key = (n, str(device), str(dtype))\n",
        "    if key not in _PADE13_CONSTS_CACHE:\n",
        "        b = torch.tensor([\n",
        "            64764752532480000.0,\n",
        "            32382376266240000.0,\n",
        "            7771770303897600.0,\n",
        "            1187353796428800.0,\n",
        "            129060195264000.0,\n",
        "            10559470521600.0,\n",
        "            670442572800.0,\n",
        "            33522128640.0,\n",
        "            1323241920.0,\n",
        "            40840800.0,\n",
        "            960960.0,\n",
        "            16380.0,\n",
        "            182.0,\n",
        "            1.0\n",
        "        ], device=device, dtype=dtype)\n",
        "        theta_13 = torch.tensor(5.371920351148152, device=device, dtype=dtype)\n",
        "        I = torch.eye(n, device=device, dtype=dtype)\n",
        "        _PADE13_CONSTS_CACHE[key] = (b, theta_13, I)\n",
        "    return _PADE13_CONSTS_CACHE[key]\n",
        "\n",
        "\n",
        "def expm_pade13_prepare(A: torch.Tensor):\n",
        "\n",
        "\n",
        "    assert A.ndim == 2 and A.shape[0] == A.shape[1]\n",
        "    n = A.shape[0]\n",
        "    dev = A.device\n",
        "    dtype = A.dtype\n",
        "\n",
        "    b, theta_13, I = _get_pade13_consts(n, dev, dtype)\n",
        "\n",
        "    # norm-1\n",
        "    A_norm1 = mat_norm1(A)\n",
        "\n",
        "    # Small-norm branches (m = 3,5,7,9)\n",
        "    ell3 = 1.495585217958292e-02\n",
        "    ell5 = 2.539398330063230e-01\n",
        "    ell7 = 9.504178996162932e-01\n",
        "    ell9 = 2.097847961257068e+00\n",
        "\n",
        "    m = None\n",
        "    if A_norm1 <= ell3:\n",
        "        m = 3\n",
        "    elif A_norm1 <= ell5:\n",
        "        m = 5\n",
        "    elif A_norm1 <= ell7:\n",
        "        m = 7\n",
        "    elif A_norm1 <= ell9:\n",
        "        m = 9\n",
        "\n",
        "    # ---- small m case ----\n",
        "    if m is not None:\n",
        "        U, V = pade_uv(A, m, I)\n",
        "        K = V - U\n",
        "        LU, piv = torch.linalg.lu_factor(K)\n",
        "        R = torch.linalg.lu_solve(LU, piv, V + U)\n",
        "        cache = {\n",
        "            \"branch\": \"small\",\n",
        "            \"m\": m,\n",
        "            \"A\": A,\n",
        "            \"I\": I,\n",
        "            \"R\": R,\n",
        "            \"LU\": LU,\n",
        "            \"piv\": piv,\n",
        "        }\n",
        "        return R, cache\n",
        "\n",
        "    # ---- scaling for pade13 ----\n",
        "    if A_norm1 <= theta_13:\n",
        "        s = 0\n",
        "        scale = 1.0\n",
        "        A_s = A\n",
        "    else:\n",
        "        s = int(torch.ceil(torch.log2(A_norm1 / theta_13)).item())\n",
        "        scale = 2.0 ** (-s)\n",
        "        A_s = A * scale\n",
        "\n",
        "    # Powers\n",
        "    A2 = A_s @ A_s\n",
        "    A4 = A2 @ A2\n",
        "    A6 = A2 @ A4\n",
        "\n",
        "    # Build U,V (Padé-13)\n",
        "    W1 = b[13]*A6 + b[11]*A4 + b[9]*A2\n",
        "    W2 = b[7]*A6  + b[5]*A4  + b[3]*A2 + b[1]*I\n",
        "    Z1 = b[12]*A6 + b[10]*A4 + b[8]*A2\n",
        "    Z2 = b[6]*A6  + b[4]*A4  + b[2]*A2 + b[0]*I\n",
        "\n",
        "    W  = A6 @ W1 + W2\n",
        "    U  = A_s @ W\n",
        "    V  = A6 @ Z1 + Z2\n",
        "\n",
        "    # Solve once (LU cached)\n",
        "    K = V - U\n",
        "    LU, piv = torch.linalg.lu_factor(K)\n",
        "    R0 = torch.linalg.lu_solve(LU, piv, V + U)  # expm(A_s)\n",
        "\n",
        "    # Store R before each squaring\n",
        "    R_steps = []\n",
        "    R = R0\n",
        "    for _ in range(s):\n",
        "        R_steps.append(R)\n",
        "        R = R @ R\n",
        "    R_final = R  # expm(A)\n",
        "\n",
        "    cache = {\n",
        "        \"branch\": \"pade13\",\n",
        "        \"b\": b,\n",
        "        \"I\": I,\n",
        "        \"s\": s,\n",
        "        \"scale\": scale,\n",
        "        \"A_s\": A_s,\n",
        "        \"A2\": A2,\n",
        "        \"A4\": A4,\n",
        "        \"A6\": A6,\n",
        "        \"W\": W,\n",
        "        \"W1\": W1,\n",
        "        \"Z1\": Z1,\n",
        "        \"LU\": LU,\n",
        "        \"piv\": piv,\n",
        "        \"R0\": R0,\n",
        "        \"R_steps\": R_steps,\n",
        "    }\n",
        "    return R_final, cache\n",
        "\n",
        "\n",
        "def expm_frechet_from_cache(cache: dict, E: torch.Tensor):\n",
        "    \"\"\"\n",
        "    Given cache from expm_pade13_prepare(A), compute L = FrechetExp(A)[E]\n",
        "    WITHOUT recomputing expm(A) and WITHOUT refactorizing K.\n",
        "    \"\"\"\n",
        "    if cache[\"branch\"] == \"small\":\n",
        "        m   = cache[\"m\"]\n",
        "        A   = cache[\"A\"]\n",
        "        I   = cache[\"I\"]\n",
        "        R   = cache[\"R\"]\n",
        "        LU  = cache[\"LU\"]\n",
        "        piv = cache[\"piv\"]\n",
        "\n",
        "        Lu, Lv = pade_frechet_LuLv(A, E, m, I)\n",
        "        rhs_L = (Lu + Lv) + (Lu - Lv) @ R\n",
        "        L = torch.linalg.lu_solve(LU, piv, rhs_L)\n",
        "        return L\n",
        "\n",
        "    # pade13 branch\n",
        "    b     = cache[\"b\"]\n",
        "    I     = cache[\"I\"]\n",
        "    s     = cache[\"s\"]\n",
        "    scale = cache[\"scale\"]\n",
        "    A_s   = cache[\"A_s\"]\n",
        "    A2    = cache[\"A2\"]\n",
        "    A4    = cache[\"A4\"]\n",
        "    A6    = cache[\"A6\"]\n",
        "    W     = cache[\"W\"]\n",
        "    W1    = cache[\"W1\"]\n",
        "    Z1    = cache[\"Z1\"]\n",
        "    LU    = cache[\"LU\"]\n",
        "    piv   = cache[\"piv\"]\n",
        "    R0    = cache[\"R0\"]\n",
        "    R_steps = cache[\"R_steps\"]\n",
        "\n",
        "    E_s = E * scale\n",
        "\n",
        "    # Frechet powers\n",
        "    M2 = A_s @ E_s + E_s @ A_s\n",
        "    M4 = A2 @ M2 + M2 @ A2\n",
        "    M6 = A4 @ M2 + M4 @ A2\n",
        "\n",
        "    # Build Lu, Lv\n",
        "    Lw1 = b[13]*M6 + b[11]*M4 + b[9]*M2\n",
        "    Lw2 = b[7]*M6  + b[5]*M4  + b[3]*M2\n",
        "    Lz1 = b[12]*M6 + b[10]*M4 + b[8]*M2\n",
        "    Lz2 = b[6]*M6  + b[4]*M4  + b[2]*M2\n",
        "\n",
        "    Lw = A6 @ Lw1 + M6 @ W1 + Lw2\n",
        "    Lu = A_s @ Lw + E_s @ W\n",
        "    Lv = A6 @ Lz1 + M6 @ Z1 + Lz2\n",
        "\n",
        "    rhs_L = (Lu + Lv) + (Lu - Lv) @ R0\n",
        "    L = torch.linalg.lu_solve(LU, piv, rhs_L)\n",
        "\n",
        "    # Squaring loop using stored R's\n",
        "    for Rk in R_steps:\n",
        "        L = Rk @ L + L @ Rk\n",
        "    return L\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "HiBAc5jbizRg"
      },
      "outputs": [],
      "source": [
        "def run_ourmethod_learn_A_xstar(\n",
        "    X0,\n",
        "    Y_obs,\n",
        "    t_span,\n",
        "    Mask,\n",
        "    expm_frechet_alg64_pade13,\n",
        "    epochs=5000,\n",
        "    lr_A=3e-3,\n",
        "    lr_xs=3e-3,\n",
        "    K_time=None,\n",
        "    delta=0.07,\n",
        "    eps=1e-12,\n",
        "    print_every=1000,\n",
        "    seed=0,\n",
        "    do_print=True,\n",
        "    init_A=None\n",
        "):\n",
        "    \"\"\"\n",
        "\n",
        "    Inputs from  data-generation function:\n",
        "      X0:   [B,G]\n",
        "      Y_obs:[B,T,G]\n",
        "      t_span:[T]\n",
        "      Mask: [G,G] bool\n",
        "    Returns:\n",
        "      A, x_star, Y_pred, loss_hist, total_sec\n",
        "    \"\"\"\n",
        "\n",
        "    assert X0.dim() == 2 and Y_obs.dim() == 3\n",
        "    B, T, G = Y_obs.shape\n",
        "    device, dtype = Y_obs.device, Y_obs.dtype\n",
        "    time=None,\n",
        "    delta=0.07,\n",
        "    eps=1e-12,\n",
        "    X0 = X0.to(device=device, dtype=dtype)\n",
        "    t_span = t_span.to(device=device, dtype=dtype)\n",
        "    Mask = Mask.to(device=device)\n",
        "\n",
        "    # Mask as float\n",
        "    Mask_f = Mask.to(device=device, dtype=dtype)\n",
        "    def apply_mask(A):\n",
        "        return A * Mask_f\n",
        "\n",
        "    # Hyperparams\n",
        "    if K_time is None:\n",
        "        K_time = min(1, T)\n",
        "    else:\n",
        "        K_time = min(K_time, T)\n",
        "\n",
        "    # Initialize parameters\n",
        "    torch.manual_seed(seed)\n",
        "\n",
        "    if init_A is None:\n",
        "      A = apply_mask(0.01 * torch.randn(G, G, device=device, dtype=dtype))\n",
        "    else:\n",
        "      A = apply_mask(init_A.clone().to(device=device, dtype=dtype))\n",
        "    # init x_star from last 10 timepoints mean\n",
        "    x_star = Y_obs[:, -10:, :].mean(dim=(0, 1)).detach().clone().to(device=device, dtype=dtype)\n",
        "\n",
        "    # Adam states (manual Adam)\n",
        "    beta1, beta2 = 0.9, 0.999\n",
        "    mA = torch.zeros_like(A); vA = torch.zeros_like(A)\n",
        "    mx = torch.zeros_like(x_star); vx = torch.zeros_like(x_star)\n",
        "    adam_eps = 1e-8\n",
        "\n",
        "    I = torch.eye(G, device=device, dtype=dtype)\n",
        "\n",
        "    # constants (create ONCE; avoids per-iter allocations)\n",
        "    one     = torch.tensor(1.0, device=device, dtype=dtype)\n",
        "    delta_t = torch.tensor(delta, device=device, dtype=dtype)\n",
        "    eps_t   = torch.tensor(eps, device=device, dtype=dtype)\n",
        "\n",
        "    # Training loop\n",
        "    if device.type == \"cuda\":\n",
        "        torch.cuda.synchronize()\n",
        "    t0 = time.time()\n",
        "\n",
        "    loss_hist = []\n",
        "\n",
        "    for ep in range(1, epochs + 1):\n",
        "        # sample time indices on CPU (works for both CPU/GPU)\n",
        "        idx_list = torch.randint(1, T, (K_time,), device=\"cpu\").tolist()\n",
        "\n",
        "        gradA = torch.zeros_like(A)\n",
        "        gradx = torch.zeros_like(x_star)\n",
        "        loss_acc = torch.zeros((), device=device, dtype=dtype)\n",
        "\n",
        "        # compute once per epoch\n",
        "        A_eff = apply_mask(A)\n",
        "\n",
        "        # batch all selected timepoints\n",
        "        idx = torch.tensor(idx_list, device=device)                 # [K]\n",
        "        t_vec = t_span.index_select(0, idx)                         # [K]\n",
        "        X_batch = t_vec[:, None, None] * A_eff[None, :, :]          # [K,G,G]\n",
        "\n",
        "        # One big GPU call instead of K separate expm calls:\n",
        "        R_batch = torch.matrix_exp(X_batch)                         # [K,G,G]\n",
        "\n",
        "        for k in range(len(idx_list)):\n",
        "            i = int(idx[k].item())\n",
        "            t = t_vec[k]\n",
        "            if t.abs() < 1e-15:\n",
        "                contin\n",
        "\n",
        "            R = R_batch[k]\n",
        "\n",
        "\n",
        "            _, cache = expm_pade13_prepare(X_batch[k])\n",
        "\n",
        "\n",
        "            # D: [G,B] with columns d_b = x0_b - x*\n",
        "            D = (X0 - x_star).T  # [G,B]\n",
        "\n",
        "            # C: [G,B] with columns c_b = y_obs(b,i) - x*\n",
        "            C = (Y_obs[:, i, :] - x_star).T  # [G,B]\n",
        "\n",
        "            # residuals for all batch: R @ D - C  => [G,B]\n",
        "            R_D = R @ D\n",
        "            r_mat = R_D - C  # [G,B]\n",
        "\n",
        "            # norms per batch: [B]\n",
        "            rnorm = torch.linalg.norm(r_mat, dim=0)\n",
        "\n",
        "            # alpha per batch: [B]\n",
        "            alpha = torch.minimum(one, delta_t / (rnorm + eps_t))  # [B]\n",
        "\n",
        "            # g_mat = -r_mat: [G,B]\n",
        "            g_mat = -r_mat\n",
        "\n",
        "            # Build ONE combined E_total = sum_b alpha_b * (t * d_b g_b^T)\n",
        "            # D_alpha: [G,B]\n",
        "            D_alpha = D * alpha.unsqueeze(0)\n",
        "            E_total = t * (D_alpha @ g_mat.T)  # [G,G]\n",
        "\n",
        "            # ONE Frechet call\n",
        "            L_total = expm_frechet_from_cache(cache, E_total)\n",
        "            gradA = gradA + (-(L_total.T))\n",
        "\n",
        "            # gradx: sum_b alpha_b * (I-R)^T r_b\n",
        "            Bmat = (I - R)  # [G,G]\n",
        "            r_weighted = r_mat * alpha.unsqueeze(0)  # [G,B]\n",
        "            gradx = gradx + (Bmat.T @ r_weighted).sum(dim=1)  # [G]\n",
        "\n",
        "            # huber loss vectorized over batch\n",
        "            huber_each = torch.where(\n",
        "                rnorm <= delta_t,\n",
        "                0.5 * rnorm**2,\n",
        "                delta_t * (rnorm - 0.5 * delta_t)\n",
        "            )  # [B]\n",
        "            loss_acc = loss_acc + huber_each.sum() / G\n",
        "\n",
        "        denom = max(1, (B * K_time))\n",
        "        gradA = gradA / (denom * G)\n",
        "        gradx = gradx / (denom * G)\n",
        "\n",
        "        # Update A (manual Adam)\n",
        "        mA = beta1*mA + (1-beta1)*gradA\n",
        "        vA = beta2*vA + (1-beta2)*(gradA*gradA)\n",
        "        mA_hat = mA / (1 - beta1**ep)\n",
        "        vA_hat = vA / (1 - beta2**ep)\n",
        "        A = A - lr_A * (mA_hat / (torch.sqrt(vA_hat) + adam_eps))\n",
        "        A = apply_mask(A)\n",
        "\n",
        "        # Update x_star (manual Adam)\n",
        "        mx = beta1*mx + (1-beta1)*gradx\n",
        "        vx = beta2*vx + (1-beta2)*(gradx*gradx)\n",
        "        mx_hat = mx / (1 - beta1**ep)\n",
        "        vx_hat = vx / (1 - beta2**ep)\n",
        "        x_star = x_star - lr_xs * (mx_hat / (torch.sqrt(vx_hat) + adam_eps))\n",
        "\n",
        "        # logging\n",
        "        if do_print and (print_every is not None) and (ep % print_every == 0 or ep == 1):\n",
        "            if device.type == \"cuda\":\n",
        "                torch.cuda.synchronize()\n",
        "            print(f\"epoch {ep:04d} | huber loss {(loss_acc/denom).item():.4e} | \"\n",
        "            f\"||A||_F {torch.linalg.norm(A).item():.3e} | \"\n",
        "            f\"||x*|| {torch.linalg.norm(x_star).item():.3e}\")\n",
        "\n",
        "        loss_hist.append(float((loss_acc/denom).item()))\n",
        "\n",
        "    if device.type == \"cuda\":\n",
        "        torch.cuda.synchronize()\n",
        "    total_sec = time.time() - t0\n",
        "    if do_print:\n",
        "        print(f\"TOTAL TIME FOR EPOCH {epochs}: {total_sec:.3f} sec\")\n",
        "\n",
        "    # Predict full trajectory for plotting\n",
        "    A_eff = apply_mask(A)\n",
        "    E_all = torch.matrix_exp(A_eff.unsqueeze(0) * t_span.view(T, 1, 1))  # [T,G,G]\n",
        "    Y_pred = torch.einsum('tij,bj->bti', E_all, (X0 - x_star)) + x_star\n",
        "\n",
        "    return A, x_star, Y_pred, loss_hist, total_sec\n"
      ]
    },
