        "#  run_autodiff_LTI\n",
        "\n",
        "import time\n",
        "import torch\n",
        "import torch.nn.functional as F\n",
        "\n",
        "def run_autodiff_LTI(\n",
        "    NumAllGene,\n",
        "    Mask,\n",
        "    X0,\n",
        "    t_span,\n",
        "    Y_obs,\n",
        "    device=None,\n",
        "    epochs=5000,\n",
        "    lr=1e-2,\n",
        "    reg_lambda=1e-4,\n",
        "    TIME_IT=True,\n",
        "    print_every=1000,\n",
        "    verbose=True,\n",
        "    init_W=None,\n",
        "    K_time=None,\n",
        "):\n",
        "    if device is None:\n",
        "        device = X0.device\n",
        "\n",
        "    # Learnable x_star\n",
        "    model = LTIExact(NumAllGene, Mask).to(device=device, dtype=Y_obs.dtype)\n",
        "\n",
        "    # init A (W)\n",
        "    if init_W is not None:\n",
        "        with torch.no_grad():\n",
        "            model.W.copy_(init_W.to(device=device, dtype=model.W.dtype))\n",
        "\n",
        "    # init x_star  (mean of last 10 timepoints)\n",
        "    with torch.no_grad():\n",
        "        model.x_star.copy_(Y_obs[:, -10:, :].mean(dim=(0, 1)).to(device=device, dtype=model.x_star.dtype))\n",
        "\n",
        "    # optimizer learns BOTH W and x_star\n",
        "    #opt = torch.optim.Adam(model.parameters(), lr=lr)\n",
        "    lr_W = 3e-3\n",
        "    lr_x = 3e-3\n",
        "    opt = torch.optim.Adam([\n",
        "        {\"params\": [model.W],      \"lr\": lr_W},\n",
        "        {\"params\": [model.x_star], \"lr\": lr_x},\n",
        "    ])\n",
        "\n",
        "    if verbose:\n",
        "        print(\"device:\", device)\n",
        "        print(\"model device:\", next(model.parameters()).device)\n",
        "        print(\"X0 device:\", X0.device, \"dtype:\", X0.dtype)\n",
        "        print(\"t_span device:\", t_span.device, \"dtype:\", t_span.dtype)\n",
        "        print(\"Y_obs device:\", Y_obs.device, \"dtype:\", Y_obs.dtype)\n",
        "\n",
        "    total_sec = None\n",
        "    if TIME_IT:\n",
        "        if device.type == \"cuda\":\n",
        "            torch.cuda.synchronize()\n",
        "        t_start = time.perf_counter()\n",
        "\n",
        "    loss_history = []\n",
        "    T = Y_obs.shape[1]\n",
        "\n",
        "    for epoch in range(epochs):\n",
        "        opt.zero_grad(set_to_none=True)\n",
        "\n",
        "        #  time subsampling affects BOTH forward + loss\n",
        "        if (K_time is None) or (K_time >= T):\n",
        "            Y_pred = model(X0, t_span)\n",
        "            loss = F.mse_loss(Y_pred, Y_obs)\n",
        "        else:\n",
        "            idx = torch.randint(1, T, (K_time,), device=device)\n",
        "            t_sub = t_span.index_select(0, idx)\n",
        "            Y_pred = model(X0, t_sub)\n",
        "            loss = F.mse_loss(Y_pred, Y_obs.index_select(1, idx))\n",
        "\n",
        "        
        "        loss = loss + reg_lambda * (model.W * model.mask).pow(2).sum()\n",
        "\n",
        "        loss.backward()\n",
        "        opt.step()\n",
        "\n",
        "        loss_history.append(float(loss.item()))\n",
        "\n",
        "        if print_every is not None and (epoch % print_every == 0):\n",
        "            print(f\"epoch {epoch:03d}  loss {loss.item():.4e}  ||x*|| {model.x_star.norm().item():.3e}\")\n",
        "\n",
        "    if TIME_IT:\n",
        "        if device.type == \"cuda\":\n",
        "            torch.cuda.synchronize()\n",
        "        total_sec = time.perf_counter() - t_start\n",
        "        if verbose:\n",
        "            print(f\"\\nTOTAL TIME FOR {epochs} EPOCH: {total_sec:.3f} seconds\")\n",
        "\n",
        "    return loss_history, total_sec, model"
      ],
      "metadata": {
        "id": "wpZPMxSc7RZU"
      },
      "execution_count": null,
      "outputs": []
